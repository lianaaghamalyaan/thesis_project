 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Grid Dynamics Armenia Jobs Scraping\n",
    "\n",
    "Scrapes Yerevan job postings from Grid Dynamics' careers page.\n",
    "\n",
    "**ATS:** Custom (WordPress + Angular widget with embedded JSON)  \n",
    "**Method:** WordPress REST API (`/wp-json/wp/v2/pages/51061`) → parse embedded jobs JSON → filter Yerevan  \n",
    "**Output:** `data/raw/jobs/griddynamics_jobs_raw.csv`, `data/processed/jobs/griddynamics_jobs_standardized.csv`\n",
    "\n",
    "11 Yerevan jobs found at time of build (2026-03-24)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re, json, requests, pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "from pathlib import Path\n",
    "\n",
    "_nb_path = globals().get('__vsc_ipynb_file__') or globals().get('__file__', None)\n",
    "if _nb_path:\n",
    "    import os; os.chdir(Path(_nb_path).resolve().parent.parent.parent)\n",
    "elif not (Path.cwd() / 'data').exists():\n",
    "    _root = Path.cwd()\n",
    "    for _ in range(4):\n",
    "        if (_root / 'data').exists(): break\n",
    "        _root = _root.parent\n",
    "    import os; os.chdir(_root)\n",
    "\n",
    "CAREERS_URL = 'https://www.griddynamics.com/careers/discover-openings'\n",
    "WP_API_URL  = 'https://www.griddynamics.com/wp-json/wp/v2/pages/51061'\n",
    "HEADERS     = {'User-Agent': 'ThesisResearch/1.0 (Armenian IT curriculum alignment; academic use)'}\n",
    "RAW_DIR     = Path.cwd() / 'data/raw/jobs'\n",
    "PROC_DIR    = Path.cwd() / 'data/processed/jobs'\n",
    "print(f'Careers URL: {CAREERS_URL}')\n",
    "print(f'WP API:      {WP_API_URL}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strategy 1: WordPress REST API — page content contains the jobs JSON blob\n",
    "resp = requests.get(WP_API_URL, headers=HEADERS, timeout=20)\n",
    "print(f'WP API status: {resp.status_code}')\n",
    "\n",
    "all_jobs = []\n",
    "\n",
    "if resp.status_code == 200:\n",
    "    page_data = resp.json()\n",
    "    # Jobs are embedded in the page content as a JSON string in a script/shortcode\n",
    "    content_raw = page_data.get('content', {}).get('rendered', '') or json.dumps(page_data)\n",
    "    \n",
    "    # Look for JSON array of job objects\n",
    "    json_matches = re.findall(r'\\[\\s*\\{[^\\[\\]]{100,}\\}\\s*\\]', content_raw)\n",
    "    for m in json_matches:\n",
    "        try:\n",
    "            candidates = json.loads(m)\n",
    "            if isinstance(candidates, list) and candidates and isinstance(candidates[0], dict):\n",
    "                if any(k in candidates[0] for k in ['title', 'location', 'city', 'category', 'department']):\n",
    "                    all_jobs = candidates\n",
    "                    print(f'Found jobs array: {len(all_jobs)} jobs')\n",
    "                    print(f'Keys: {list(all_jobs[0].keys())}')\n",
    "                    break\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "print(f'Total jobs parsed: {len(all_jobs)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strategy 2: Scrape the filtered careers page directly\n",
    "if not all_jobs:\n",
    "    print('WP API did not yield jobs — falling back to careers page scrape')\n",
    "    yerevan_url = f'{CAREERS_URL}?city=Yerevan%2C+Armenia'\n",
    "    resp2 = requests.get(yerevan_url, headers=HEADERS, timeout=20)\n",
    "    soup  = BeautifulSoup(resp2.text, 'html.parser')\n",
    "    \n",
    "    # Look for JSON in script tags\n",
    "    for script in soup.find_all('script'):\n",
    "        text = script.string or ''\n",
    "        if 'Yerevan' in text and ('title' in text or 'position' in text):\n",
    "            json_matches = re.findall(r'\\[\\s*\\{.{50,}\\}\\s*\\]', text, re.DOTALL)\n",
    "            for m in json_matches[:3]:\n",
    "                try:\n",
    "                    candidates = json.loads(m)\n",
    "                    if isinstance(candidates, list) and candidates:\n",
    "                        all_jobs = candidates\n",
    "                        print(f'Found {len(all_jobs)} jobs in script tag')\n",
    "                        print(f'Keys: {list(all_jobs[0].keys()) if isinstance(all_jobs[0], dict) else type(all_jobs[0])}')\n",
    "                        break\n",
    "                except Exception:\n",
    "                    pass\n",
    "            if all_jobs: break\n",
    "    \n",
    "    # Show page structure for manual debugging\n",
    "    if not all_jobs:\n",
    "        print('Could not extract JSON. Page structure:')\n",
    "        print(soup.title.text if soup.title else 'no title')\n",
    "        scripts_with_data = [s.string[:200] for s in soup.find_all('script') \n",
    "                             if s.string and len(s.string) > 500]\n",
    "        print(f'{len(scripts_with_data)} large script tags found')\n",
    "        for i, s in enumerate(scripts_with_data[:3]):\n",
    "            print(f'  [{i}] {s[:300]}')\n",
    "\n",
    "print(f'Total jobs available: {len(all_jobs)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Filter for Yerevan and build records\n",
    "def is_yerevan(job):\n",
    "    searchable = json.dumps(job).lower()\n",
    "    return 'yerevan' in searchable or 'armenia' in searchable\n",
    "\n",
    "yerevan_jobs = [j for j in all_jobs if is_yerevan(j)] if all_jobs else []\n",
    "\n",
    "print(f'Yerevan jobs: {len(yerevan_jobs)}')\n",
    "for j in yerevan_jobs:\n",
    "    title    = j.get('title') or j.get('name') or j.get('position', '')\n",
    "    location = j.get('location') or j.get('city') or j.get('office', '')\n",
    "    category = j.get('category') or j.get('department') or j.get('team', '')\n",
    "    print(f'  {title:<55} | {location:<25} | {category}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_field(job, *keys):\n",
    "    for k in keys:\n",
    "        v = job.get(k, '')\n",
    "        if v: return str(v)\n",
    "    return ''\n",
    "\n",
    "records = []\n",
    "for j in yerevan_jobs:\n",
    "    # Build full_text from all text fields\n",
    "    text_parts = []\n",
    "    for k, v in j.items():\n",
    "        if isinstance(v, str) and len(v) > 30 and k not in ('id', 'url', 'link', 'applyUrl'):\n",
    "            clean = BeautifulSoup(v, 'html.parser').get_text('\\n', strip=True)\n",
    "            text_parts.append(clean)\n",
    "    full_text = re.sub(r'\\n{3,}', '\\n\\n', '\\n\\n'.join(text_parts)).strip()\n",
    "    \n",
    "    records.append({\n",
    "        'source':          'griddynamics',\n",
    "        'source_type':     'company_portal',\n",
    "        'source_url':      extract_field(j, 'url', 'link', 'applyUrl'),\n",
    "        'job_title':       extract_field(j, 'title', 'name', 'position'),\n",
    "        'company_name':    'Grid Dynamics',\n",
    "        'location':        extract_field(j, 'location', 'city', 'office'),\n",
    "        'department':      extract_field(j, 'category', 'department', 'team'),\n",
    "        'employment_type': extract_field(j, 'type', 'employmentType', 'commitment'),\n",
    "        'seniority_level': '',\n",
    "        'industries':      'Technology / IT Services',\n",
    "        'posting_date':    extract_field(j, 'date', 'publishedAt', 'createdAt'),\n",
    "        'skills_tags':     '',\n",
    "        'full_text':       full_text,\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(records)\n",
    "RAW_DIR.mkdir(parents=True, exist_ok=True)\n",
    "PROC_DIR.mkdir(parents=True, exist_ok=True)\n",
    "df.to_csv(RAW_DIR / 'griddynamics_jobs_raw.csv', index=False)\n",
    "df.to_csv(PROC_DIR / 'griddynamics_jobs_standardized.csv', index=False)\n",
    "print(f'Saved {len(df)} rows')\n",
    "if len(df):\n",
    "    print(df[['job_title', 'location', 'department']].to_string())"
   ]
  }
 ],
