   "source": [
    "# TeamViewer Armenia Jobs Scraping\n",
    "\n",
    "Scrapes Armenia/Yerevan job postings from TeamViewer's TeamTailor-hosted careers portal.\n",
    "\n",
    "**ATS:** TeamTailor (`careers.teamviewer.com`)  \n",
    "**Method:** TeamTailor JSON API → filter by Yerevan location  \n",
    "**Output:** `data/raw/jobs/teamviewer_jobs_raw.csv`, `data/processed/jobs/teamviewer_jobs_standardized.csv`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re, time, requests, pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "from pathlib import Path\n",
    "\n",
    "_nb_path = globals().get('__vsc_ipynb_file__') or globals().get('__file__', None)\n",
    "if _nb_path:\n",
    "    import os; os.chdir(Path(_nb_path).resolve().parent.parent.parent)\n",
    "elif not (Path.cwd() / 'data').exists():\n",
    "    _root = Path.cwd()\n",
    "    for _ in range(4):\n",
    "        if (_root / 'data').exists(): break\n",
    "        _root = _root.parent\n",
    "    import os; os.chdir(_root)\n",
    "\n",
    "BASE     = 'https://careers.teamviewer.com'\n",
    "HEADERS  = {\n",
    "    'User-Agent': 'ThesisResearch/1.0 (Armenian IT curriculum alignment; academic use)',\n",
    "    'Accept': 'application/json, text/javascript, */*',\n",
    "    'X-Requested-With': 'XMLHttpRequest',\n",
    "}\n",
    "RAW_DIR  = Path.cwd() / 'data/raw/jobs'\n",
    "PROC_DIR = Path.cwd() / 'data/processed/jobs'\n",
    "print(f'Base: {BASE}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def html_to_text(html_str):\n",
    "    if not html_str: return ''\n",
    "    text = BeautifulSoup(str(html_str), 'html.parser').get_text('\\n', strip=True)\n",
    "    return re.sub(r'\\n{3,}', '\\n\\n', text).strip()\n",
    "\n",
    "# TeamTailor JSON API — try the standard endpoint\n",
    "api_url = f'{BASE}/jobs.json'\n",
    "resp = requests.get(api_url, headers=HEADERS, timeout=20)\n",
    "print(f'Status: {resp.status_code}')\n",
    "print(f'Content-Type: {resp.headers.get(\"Content-Type\", \"\")}')\n",
    "\n",
    "if resp.status_code == 200 and 'json' in resp.headers.get('Content-Type', ''):\n",
    "    data = resp.json()\n",
    "    print(f'JSON keys: {list(data.keys()) if isinstance(data, dict) else type(data)}')\n",
    "else:\n",
    "    print('JSON API not available at /jobs.json — will try HTML scraping')\n",
    "    print(resp.text[:500])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# TeamTailor: try fetching the jobs page with location filter\n",
    "# TeamTailor supports ?location= query param\n",
    "for location_query in ['Yerevan', 'Armenia', '']:\n",
    "    url = f'{BASE}/jobs' if not location_query else f'{BASE}/jobs?location={location_query}'\n",
    "    resp = requests.get(url, headers={'User-Agent': 'ThesisResearch/1.0'}, timeout=20)\n",
    "    soup = BeautifulSoup(resp.text, 'html.parser')\n",
    "    \n",
    "    # TeamTailor job cards are typically in <li> elements with data-job-id\n",
    "    job_items = soup.find_all(attrs={'data-job-id': True})\n",
    "    if not job_items:\n",
    "        # Try alternative selectors\n",
    "        job_items = soup.find_all('li', class_=lambda c: c and 'job' in ' '.join(c).lower())\n",
    "    \n",
    "    print(f'\\nQuery: {location_query or \"(all)\"} → {len(job_items)} job items found')\n",
    "    \n",
    "    if job_items:\n",
    "        for item in job_items[:5]:\n",
    "            print(f'  {str(item)[:150]}')\n",
    "        break\n",
    "    \n",
    "    # Show page structure for debugging\n",
    "    if not location_query:\n",
    "        print('  Page title:', soup.title.text if soup.title else 'N/A')\n",
    "        print('  Sample links:', [a['href'] for a in soup.find_all('a', href=True) if '/jobs/' in a.get('href','')][:5])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# TeamTailor: scrape job listing page and collect Armenia jobs\n",
    "resp = requests.get(f'{BASE}/jobs', headers={'User-Agent': 'ThesisResearch/1.0'}, timeout=20)\n",
    "soup = BeautifulSoup(resp.text, 'html.parser')\n",
    "\n",
    "# Find all job links\n",
    "job_links = []\n",
    "for a in soup.find_all('a', href=True):\n",
    "    href = a['href']\n",
    "    if '/jobs/' in href and href not in job_links:\n",
    "        job_links.append(href)\n",
    "\n",
    "print(f'Job links found: {len(job_links)}')\n",
    "for link in job_links[:10]:\n",
    "    print(f'  {link}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fetch each job page and check location\n",
    "records = []\n",
    "armenia_count = 0\n",
    "\n",
    "for href in job_links:\n",
    "    url = href if href.startswith('http') else BASE + href\n",
    "    try:\n",
    "        r    = requests.get(url, headers={'User-Agent': 'ThesisResearch/1.0'}, timeout=15)\n",
    "        soup = BeautifulSoup(r.text, 'html.parser')\n",
    "        \n",
    "        # Extract location — TeamTailor typically has it in a dedicated element\n",
    "        location_el = soup.find(attrs={'data-qa': 'job-location'}) or \\\n",
    "                      soup.find(class_=lambda c: c and 'location' in ' '.join(c).lower())\n",
    "        location = location_el.get_text(strip=True) if location_el else ''\n",
    "        \n",
    "        if 'yerevan' not in location.lower() and 'armenia' not in location.lower():\n",
    "            time.sleep(0.3)\n",
    "            continue\n",
    "        \n",
    "        armenia_count += 1\n",
    "        title_el = soup.find('h1') or soup.find('h2')\n",
    "        title    = title_el.get_text(strip=True) if title_el else href.split('/')[-1]\n",
    "        \n",
    "        # Get full job text\n",
    "        for tag in soup.find_all(['nav', 'footer', 'header']):\n",
    "            tag.decompose()\n",
    "        body = soup.find('body')\n",
    "        full_text = re.sub(r'\\n{3,}', '\\n\\n', body.get_text('\\n', strip=True)) if body else ''\n",
    "        \n",
    "        print(f'  ARMENIA: {title[:60]} | {location}')\n",
    "        records.append({\n",
    "            'source':          'teamviewer',\n",
    "            'source_type':     'company_portal',\n",
    "            'source_url':      url,\n",
    "            'job_title':       title,\n",
    "            'company_name':    'TeamViewer',\n",
    "            'location':        location,\n",
    "            'department':      '',\n",
    "            'employment_type': '',\n",
    "            'seniority_level': '',\n",
    "            'industries':      'Technology / Remote Access Software',\n",
    "            'posting_date':    '',\n",
    "            'skills_tags':     '',\n",
    "            'full_text':       full_text,\n",
    "        })\n",
    "        time.sleep(1.0)\n",
    "    except Exception as e:\n",
    "        print(f'  Error on {url}: {e}')\n",
    "        time.sleep(0.5)\n",
    "\n",
    "print(f'\\nArmenia jobs found: {armenia_count}')\n",
    "df = pd.DataFrame(records)\n",
    "RAW_DIR.mkdir(parents=True, exist_ok=True)\n",
    "PROC_DIR.mkdir(parents=True, exist_ok=True)\n",
    "df.to_csv(RAW_DIR / 'teamviewer_jobs_raw.csv', index=False)\n",
    "df.to_csv(PROC_DIR / 'teamviewer_jobs_standardized.csv', index=False)\n",
    "print(f'Saved {len(df)} rows')"
   ]
  }
