   "source": [
    "# NVIDIA Armenia Jobs Scraping\n",
    "\n",
    "Scrapes Armenia/Yerevan job postings from NVIDIA's Lever-hosted careers portal.\n",
    "\n",
    "**ATS:** Lever (`api.lever.co/v0/postings/nvidia`)  \n",
    "**Method:** Lever public API → filter by Armenia/Yerevan location  \n",
    "**Output:** `data/raw/jobs/nvidia_jobs_raw.csv`, `data/processed/jobs/nvidia_jobs_standardized.csv`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re, requests, pandas as pd\n",
    "from bs4 import BeautifulSoup\n",
    "from pathlib import Path\n",
    "\n",
    "_nb_path = globals().get('__vsc_ipynb_file__') or globals().get('__file__', None)\n",
    "if _nb_path:\n",
    "    import os; os.chdir(Path(_nb_path).resolve().parent.parent.parent)\n",
    "elif not (Path.cwd() / 'data').exists():\n",
    "    _root = Path.cwd()\n",
    "    for _ in range(4):\n",
    "        if (_root / 'data').exists(): break\n",
    "        _root = _root.parent\n",
    "    import os; os.chdir(_root)\n",
    "\n",
    "LEVER_URL = 'https://api.lever.co/v0/postings/nvidia'\n",
    "HEADERS   = {'User-Agent': 'ThesisResearch/1.0 (Armenian IT curriculum alignment; academic use)'}\n",
    "RAW_DIR   = Path.cwd() / 'data/raw/jobs'\n",
    "PROC_DIR  = Path.cwd() / 'data/processed/jobs'\n",
    "print(f'Lever API: {LEVER_URL}?mode=json')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def html_to_text(html_str):\n",
    "    if not html_str: return ''\n",
    "    text = BeautifulSoup(str(html_str), 'html.parser').get_text('\\n', strip=True)\n",
    "    return re.sub(r'\\n{3,}', '\\n\\n', text).strip()\n",
    "\n",
    "def build_full_text(j):\n",
    "    parts = []\n",
    "    for field in ['descriptionPlain', 'openingPlain', 'additionalPlain']:\n",
    "        val = (j.get(field) or '').strip()\n",
    "        if val: parts.append(val)\n",
    "    for lst in (j.get('lists') or []):\n",
    "        heading = lst.get('text', '')\n",
    "        content = html_to_text(lst.get('content', ''))\n",
    "        if content: parts.append(f'{heading}:\\n{content}')\n",
    "    return '\\n\\n'.join(parts).strip()\n",
    "\n",
    "def is_armenia(j):\n",
    "    loc = j.get('categories', {}).get('location', '').lower()\n",
    "    return 'yerevan' in loc or 'armenia' in loc\n",
    "\n",
    "# Fetch all postings\n",
    "resp = requests.get(LEVER_URL, headers=HEADERS, params={'mode': 'json'}, timeout=20)\n",
    "resp.raise_for_status()\n",
    "all_jobs = resp.json()\n",
    "print(f'Total NVIDIA Lever jobs: {len(all_jobs)}')\n",
    "\n",
    "# Show all unique locations\n",
    "from collections import Counter\n",
    "locs = Counter(j.get('categories', {}).get('location', 'N/A') for j in all_jobs)\n",
    "print('\\nTop locations:')\n",
    "for loc, cnt in locs.most_common(20):\n",
    "    marker = ' ← ARMENIA' if ('yerevan' in loc.lower() or 'armenia' in loc.lower()) else ''\n",
    "    print(f'  {cnt:3d}  {loc}{marker}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "armenia_jobs = [j for j in all_jobs if is_armenia(j)]\n",
    "print(f'Armenia/Yerevan jobs: {len(armenia_jobs)}')\n",
    "for j in armenia_jobs:\n",
    "    cats = j.get('categories', {})\n",
    "    print(f\"  {j['text']:<60} | {cats.get('location',''):<30} | {cats.get('team','')}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "records = []\n",
    "for j in armenia_jobs:\n",
    "    cats      = j.get('categories', {})\n",
    "    full_text = build_full_text(j)\n",
    "    records.append({\n",
    "        'source':          'nvidia',\n",
    "        'source_type':     'company_portal',\n",
    "        'source_url':      j.get('hostedUrl', ''),\n",
    "        'job_title':       j.get('text', ''),\n",
    "        'company_name':    'NVIDIA',\n",
    "        'location':        cats.get('location', ''),\n",
    "        'department':      cats.get('team', ''),\n",
    "        'employment_type': cats.get('commitment', ''),\n",
    "        'seniority_level': '',\n",
    "        'industries':      'Technology / Semiconductors',\n",
    "        'posting_date':    '',\n",
    "        'skills_tags':     '',\n",
    "        'full_text':       full_text,\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(records)\n",
    "RAW_DIR.mkdir(parents=True, exist_ok=True)\n",
    "PROC_DIR.mkdir(parents=True, exist_ok=True)\n",
    "df.to_csv(RAW_DIR / 'nvidia_jobs_raw.csv', index=False)\n",
    "df.to_csv(PROC_DIR / 'nvidia_jobs_standardized.csv', index=False)\n",
    "print(f'Saved {len(df)} rows')\n",
    "if len(df):\n",
    "    print(df[['job_title','location','department','employment_type']].to_string())"
   ]
  }
 ],
